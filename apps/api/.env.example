# Copy to .env and adjust.

# Postgres (Neon). Local dev + cloud both use Postgres now.
# Neon dashboard -> connection string. Use the pooled URL for serverless.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

PORT=3001

# AI provider: "mock" (no deps) | "ollama" (local) | "groq" (hosted, cloud)
AI_PROVIDER=groq

# Ollama (local dev only)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Groq (hosted open-source LLM — cloud/prod). Key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
